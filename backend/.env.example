# Django
DEBUG=True
SECRET_KEY=change-me-in-production-use-50-random-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (matches docker-compose service name "db")
DATABASE_URL=postgresql://postgres:postgres@db:5432/resume_parser

# Redis (matches docker-compose service name "redis")
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# LLM — Anthropic Claude (no OpenAI key needed)
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3

# Local file storage (no S3)
MEDIA_ROOT=/app/media

# CORS (frontend origins allowed to call the API)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
